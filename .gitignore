**/*.cache/
**/*.hw/
**/*.ip_user_files/
**/*.runs/
**/*.sim/
**/*.gen/
**/*.runs/
**/*.Xil/


# Logs y journals de Vivado
vivado*.log
vivado*.jou
vivado_pid*.str

# --- Vitis / SDK (Software) ---
