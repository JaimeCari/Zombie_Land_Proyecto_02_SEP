**/ps7_cortexa9_0/
**/standalone_domain/
**/_ide/
**/*.bsp
**/*.elf
**/*.mmi
**/*.o
**/*.d

# --- Archivos de Sistema y OneDrive ---
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.tmp

# --- Python ---
__pycache__/
*.py[cod]
*$py.class

